# Copy to .env on the box (next to docker-compose.yml and auto-update.sh).
# auto-update.sh manages this file after the first run; you only need to set the
# three operator/secret fields below by hand initially.

# --- Operator inputs (preserved across updates) -----------------------------

# Channel the server tracks:
#   release  - latest published vX.Y.Z GitHub release (production)
#   branch   - tip of BRANCH_REF below (dev / playtest)
CHANNEL=branch

# Used only when CHANNEL=branch. e.g. v0.7.0 for the current playtest branch.
BRANCH_REF=v0.7.0

# RCON password. Generate once:  openssl rand -hex 24
RCON_PASSWORD=change-me

# --- Resolved by auto-update.sh (leave blank on first run) ------------------
# Filled in (and pinned to a single commit) on each successful update. Do not
# hand-edit these; change CHANNEL/BRANCH_REF and let the script redeploy.
NEOFORGE_VERSION=
PACKWIZ_URL=
DEPLOYED_SHA=
DEPLOYED_VERSION=
