# Copy to .env, then set the operator fields below. auto-update.sh manages the
# rest of this file after the first run.

# --- Operator settings (kept across updates) --------------------------------

# Which version of the pack to track:
#   release  - the latest published Derpack X release (recommended)
#   branch   - the tip of BRANCH_REF below, for playtesting an upcoming version
CHANNEL=release
BRANCH_REF=v0.7.0            # used only when CHANNEL=branch

# Players allowed to join, and server operators. Comma-separated, no spaces.
WHITELIST=
OPS=

# RCON password - set your own, e.g.  openssl rand -hex 24
RCON_PASSWORD=change-me

# --- Managed by auto-update.sh (leave blank) --------------------------------
NEOFORGE_VERSION=
PACKWIZ_URL=
DEPLOYED_SHA=
DEPLOYED_VERSION=
