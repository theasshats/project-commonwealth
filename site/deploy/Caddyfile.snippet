# Add to /home/media stack/caddy/Caddyfile, matching the existing per-service
# pattern. Reverse-proxy by container NAME, never an IP (bridge IPs reshuffle
# on recreate). The only change from the brief's nginx example is the port:
# our Go service listens on 8080 (non-root can't bind 80), so it's modpack:8080.

modpack.ishimura.xyz {
	reverse_proxy modpack:8080
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
}
