# Mod jars - never committed (license + size)
mods/*.jar
mods/*.zip
mods/*.disabled

# packwiz artifacts we don't need in git
*.mrpack


# Minecraft runtime state
.minecraft/
saves/
logs/
crash-reports/
journeymap/
xaero/
screenshots/
backups/

# Per-user
options.txt
optionsof.txt
servers.dat*
usercache.json
usernamecache.json
realms_persistence.json
hotbar.nbt

# Python (scripts/ helpers)
__pycache__/
*.pyc

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Build outputs
dist/
build/
out/

# App-local state — per-user, not synced
.editor/

# Editor build outputs (we commit pcmc-edit.exe but not intermediate stuff)
tools/editor-src/bin/

# packwiz source checkout used only by the build-editor workflow
.packwiz-src/

# Downloaded build tooling (packwiz-installer-bootstrap.jar — fetched by scripts/setup.sh + the build scripts)
.tools/

# Runtime recipe dumps — local working files, NEVER committed: verbatim mod
# recipe JSON (licensing-sensitive in a public repo) and unrefreshable
# point-in-time snapshots besides. See tools/recipe-dump/README.md.
tools/recipe-dump/pcmc-recipes.*
tools/recipe-dump/dump/
